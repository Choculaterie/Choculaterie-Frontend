{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.20.0",
    "generators": {
      "backend": {
        "generatorName": "typescript-angular",
        "inputSpec": "http://localhost:5289/openapi/v1.json",
        "output": "src/app/api",
        "additionalProperties": {
          "ngVersion": "17",
          "withInterfaces": true
        }
      }
    }
  }
}